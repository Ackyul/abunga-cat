# Variables de entorno para Abunga Sabor Queretumba
# Copia este archivo como .env y llena los valores reales
# NUNCA subas el archivo .env al repositorio

# URL de conexión a la base de datos Neon Postgres (requerido para backend serverless)
DATABASE_URL=postgres://usuario:contraseña@servidor/base_de_datos?sslmode=require

# Configuración de Cloudinary para imágenes
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_URL=cloudinary://tu_api_key:tu_api_secret@tu_cloud_name

# API URL del backend (si se requiere)
VITE_API_URL=https://tu-backend.com/api

# API key pública (solo frontend, no incluyas claves secretas aquí)
# VITE_SOME_PUBLIC_KEY=

# Otras configuraciones
# VITE_APP_ENV=production
